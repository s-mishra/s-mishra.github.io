pages = {651--653},
title = {Bhatt, Ferguson, Flaxman, Gandy, Mishra, and Scott’s reply to the Discussion of ‘The Second Discussion Meeting on Statistical aspects of the Covid-19 Pandemic’},
volume = {186},
year = {2023},
